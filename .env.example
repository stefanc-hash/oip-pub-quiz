# ─── Server ───
PORT=3000
HOST=0.0.0.0
DB_PATH=./data/quiz.db
QUESTION_TIME_SECONDS=30

# ─── Admin auth ───
# Username for the admin account (defaults to "admin").
ADMIN_USERNAME=admin
# Strong, random password. Required in production.
# Generate one with:  openssl rand -hex 24
ADMIN_PASSWORD=change-me-in-dev
# HMAC key used to sign the admin session cookie. Required in production.
# Generate with:      openssl rand -hex 32
SESSION_SECRET=dev-only-not-secret
# How long a login lasts (ms). Default 12h.
SESSION_MAX_AGE_MS=43200000

# ─── Public URL (cloud deployment only) ───
# When set, the QR endpoint encodes this URL instead of detecting a LAN IP.
# Leave unset for laptop / LAN deployments.
# PUBLIC_URL=https://your-app.up.railway.app
